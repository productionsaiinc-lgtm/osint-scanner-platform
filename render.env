# Render.com Environment Variables for OSINT Scanner Platform
# Copy these to Render Dashboard → Environment → Add Environment Variables

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Set DATABASE_URL in Render Dashboard when creating PostgreSQL service
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/osint_scanner

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
JWT_SECRET=your-jwt-secret-key-change-this-in-production
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://oauth.manus.im

# ============================================================================
# MANUS PLATFORM INTEGRATION
# ============================================================================
VITE_APP_ID=your-manus-app-id
BUILT_IN_FORGE_API_URL=https://api.manus.im/forge
BUILT_IN_FORGE_API_KEY=your-manus-api-key
VITE_FRONTEND_FORGE_API_KEY=your-manus-frontend-key
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im/forge

# ============================================================================
# OWNER INFORMATION
# ============================================================================
OWNER_NAME=nate
OWNER_OPEN_ID=your-owner-open-id

# ============================================================================
# OSINT API KEYS (Required for Real Data)
# ============================================================================
# Etherscan - Blockchain data for Crypto Tracker
ETHERSCAN_API_KEY=your-etherscan-api-key

# Shodan - Internet-connected device discovery
SHODAN_API_KEY=your-shodan-api-key

# VirusTotal - Malware analysis
VIRUSTOTAL_API_KEY=your-virustotal-api-key

# OpenSky Network - Flight tracking
OPENSKY_API_KEY=your-opensky-api-key

# Numverify - Phone number validation
NUMVERIFY_API_KEY=your-numverify-api-key

# Hunter.io - Employee enumeration
HUNTER_API_KEY=your-hunter-api-key

# IMEI.info - Device identification
IMEI_API_KEY=your-imei-api-key

# ============================================================================
# PAYMENT PROCESSING (Stripe)
# ============================================================================
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ============================================================================
# PAYMENT PROCESSING (PayPal)
# ============================================================================
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=live
PAYPAL_PAYOUT_EMAIL=your-payout-email@example.com

# ============================================================================
# ANALYTICS & MONITORING
# ============================================================================
VITE_ANALYTICS_ENDPOINT=https://analytics.manus.im
VITE_ANALYTICS_WEBSITE_ID=your-website-id

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
VITE_APP_TITLE=OSINT & Pentesting Services
VITE_APP_LOGO=https://your-domain.com/logo.png

# ============================================================================
# NODE ENVIRONMENT
# ============================================================================
NODE_ENV=production

# ============================================================================
# PORT CONFIGURATION
# ============================================================================
# Render automatically assigns PORT from environment
# No need to set manually - the app will use process.env.PORT
PORT=3000

# ============================================================================
# DEPLOYMENT NOTES
# ============================================================================
# 1. Create a PostgreSQL database on Render
# 2. Copy the DATABASE_URL from Render PostgreSQL service
# 3. Add all API keys from their respective services
# 4. Set STRIPE_SECRET_KEY and PAYPAL credentials for payments
# 5. Update OWNER_NAME and OWNER_OPEN_ID with your info
# 6. Deploy using: git push origin main (if connected to GitHub)
# 7. Or use: render deploy --service-id=your-service-id
